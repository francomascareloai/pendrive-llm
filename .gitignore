# ═══════════════════════════════════════════════════════
# pendrive-llm — .gitignore global (monorepo)
# Cobertura: ornith-usb, minicpm5-1b, c-answer, Consulta_Prova_C, projeto_teste
# ═══════════════════════════════════════════════════════

# ── Modelos GGUF (pesados — baixar à parte, NUNCA versionar) ──
*.gguf
model/

# ── Motor llama.cpp (binários de terceiro — release oficial) ──
llama/

# ── Agentes de terceiro (binários) ──
crush/crush.exe
omp/omp.exe

# ── Runtime dos agentes (DBs, logs, sessões) ──
# NOTA: crush/config-xdg/ É versionado (config portátil do agente crush — fonte).
# Só crush/data/ é runtime (DBs, logs, sessões geradas em uso).
crush/data/

# ── Python (c-answer) ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# ── Artefatos de build (c-answer) ──
build/
dist/

# ── Binários (qualquer .exe/.dll no repo) ──
*.exe
*.dll
*.obj
*.o

# ── Runtime / logs / dbs / backups ──
*.log
*.bak
*.db
*.db-shm
*.db-wal
out.txt

# ── Config runtime do crush solto na raiz ──
# (NÃO ignora ornith-usb/config/ nem minicpm5-1b/config/ — esses são fonte)
/config/crush.json

# ── Lixo de teste / acidentes (saídas redirecionadas, testes temporários) ──
aaaaaa.c
ornith-usb/injection
ornith-usb/_test_*.bat
minicpm5-1b/8
/VAL
/syntax
/c-answer.spec
c-answer/response.json
Consulta_Prova_C/exemplos/example.txt

# ── Testes temporários do config.bat na raiz (test_flow, test_octal, _regex_test) ──
/test_*.bat
/test_*.ps1
/_*.bat
/_*.ps1

# ── Scripts de teste temporários dos modelos (check, idle_check, mem_test, etc.) ──
minicpm5-1b/check.ps1
minicpm5-1b/idle_check.ps1
minicpm5-1b/mem_test.ps1
minicpm5-1b/proc.ps1
minicpm5-1b/quick_test.ps1
minicpm5-1b/start-test.bat
minicpm5-1b/test_model.ps1
minicpm5-1b/teste_200linhas.ps1
minicpm5-1b/final_test.ps1
minicpm5-1b/teste_err.txt
minicpm5-1b/teste_out.txt
minicpm5-1b/req_curto.json
minicpm5-1b/resp_curto.json
minicpm5-1b/analisa_curto.ps1
minicpm5-1b/*_curto.*

# ── OS / editor ──
Thumbs.db
desktop.ini
ehthumbs.db
.DS_Store
.vscode/
.idea/
*.swp

# ── Scripts de teste temporários da auditoria ──
/_t/
